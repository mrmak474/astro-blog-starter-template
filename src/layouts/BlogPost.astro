---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_AUTHOR } from '../consts';

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  categories = [],
  tags = [],
  author = SITE_AUTHOR,
} = Astro.props as CollectionEntry<'blog'>['data'];
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={heroImage ?? '/images/hero-medical.svg'}
      type="article"
      publishedDate={pubDate.toISOString()}
      modifiedDate={updatedDate?.toISOString()}
      tags={tags}
      category={categories[0]}
      authorName={author}
    />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="site-container py-12">
      <article class="space-y-8 rounded-[36px] border border-slate-200 bg-white p-6 shadow-soft sm:p-10">
        <div class="space-y-4">
          <div class="flex flex-wrap gap-3 text-xs uppercase tracking-[0.28em] text-brand-700">
            {categories.map((category) => <span class="rounded-full bg-brand-100 px-3 py-1">{category}</span>)}
          </div>
          <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">{title}</h1>
          <div class="flex flex-col gap-2 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between">
            <span>{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            <span>By {author}</span>
          </div>
          <p class="max-w-3xl text-lg leading-8 text-slate-600">{description}</p>
        </div>
        {heroImage ? <img src={heroImage} alt={title} class="mx-auto rounded-3xl shadow-soft" /> : null}
        <div class="prose prose-slate mx-auto max-w-none"> <slot /> </div>
        <div class="space-y-4 rounded-3xl bg-slate-50 p-6 text-slate-700">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">More from MedBillingAndCoding</p>
          <div class="flex flex-wrap gap-2 text-sm text-slate-600">
            {tags.map((tag) => <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="rounded-full border border-slate-200 px-3 py-1 hover:border-brand-400 hover:text-brand-700">#{tag}</a>)}
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
