---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description="About MedBillingAndCoding and our mission to support revenue cycle professionals." />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="site-container py-12">
      <section class="rounded-[36px] border border-slate-200 bg-white p-8 shadow-soft sm:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-700">About</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">We help healthcare organizations get paid faster and more reliably.</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">MedBillingAndCoding publishes expert guidance designed for billing managers, compliance teams, and clinicians. Our content is focused on claims management, coding accuracy, denial prevention, and revenue cycle optimization.</p>
        <div class="mt-10 grid gap-8 md:grid-cols-2">
          <div class="rounded-3xl bg-slate-50 p-6">
            <h2 class="text-xl font-semibold text-slate-900">Mission</h2>
            <p class="mt-3 text-slate-600">Make billing and coding intelligence accessible to every medical practice so providers can focus on patient care while revenue teams improve cash flow.</p>
          </div>
          <div class="rounded-3xl bg-slate-50 p-6">
            <h2 class="text-xl font-semibold text-slate-900">Why this blog</h2>
            <p class="mt-3 text-slate-600">Content is tailored for busy teams: concise workflows, regulatory considerations, payer-friendly coding guidance, and data-driven revenue cycle tips.</p>
          </div>
        </div>
        <div class="mt-10 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold text-slate-900">Start improving your billing outcomes</h2>
          <p class="mt-4 text-slate-600">Review our latest posts, browse categories, or search for an article that matches your challenge.</p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a href="/blog" class="inline-flex items-center justify-center rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800">Browse the blog</a>
            <a href="/search" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 hover:border-brand-700 hover:text-brand-700">Search articles</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
