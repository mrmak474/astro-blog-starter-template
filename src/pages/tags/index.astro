---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags ?? []))).sort();
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="site-container py-12">
      <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-soft">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-700">Tags</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Browse by topic tags.</h1>
        <div class="mt-10 flex flex-wrap gap-3">
          {tags.map((tag) => (
            <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-brand-300 hover:text-brand-700">#{tag}</a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
