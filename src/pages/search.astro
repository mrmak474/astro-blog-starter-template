---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const searchData = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  href: `/blog/${post.id}/`,
  pubDate: post.data.pubDate.toISOString(),
  categories: post.data.categories ?? [],
  tags: post.data.tags ?? [],
}));
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Search | ${SITE_TITLE}`} description="Search medical billing and coding articles across categories, tags, and expert resources." />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="site-container py-12">
      <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-soft">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-700">Search</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-900">Find articles by topic, category, or keyword.</h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">Type a query to instantly filter the blog library and uncover practical guidance for revenue cycle, payer policies, and denial appeals.</p>
        <div class="mt-8">
          <label class="sr-only" for="search-query">Search blog articles</label>
          <input id="search-query" type="search" placeholder="Search topics, coding, claims, audits..." class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-6 py-4 text-lg text-slate-900 shadow-sm outline-none transition focus:border-brand-400 focus:ring-4 focus:ring-brand-100" />
        </div>
        <div id="results" class="mt-10 grid gap-6"></div>
      </section>
    </main>
    <Footer />
    <script type="application/json" id="search-data">{JSON.stringify(searchData)}</script>
    <script type="module">
      const resultsElement = document.getElementById('results');
      const searchInput = document.getElementById('search-query');
      const data = JSON.parse(document.getElementById('search-data').textContent);

      function buildCard(post) {
        return `
          <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
            <a href="${post.href}" class="block">
              <div class="mb-4 flex flex-wrap gap-2 text-xs uppercase tracking-[0.28em] text-brand-700">
                ${post.categories.map((category) => `<span class="rounded-full bg-brand-100 px-3 py-1">${category}</span>`).join('')}
              </div>
              <h2 class="text-2xl font-semibold text-slate-900">${post.title}</h2>
              <p class="mt-3 text-slate-600">${post.description}</p>
              <p class="mt-4 text-sm text-slate-500">${new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
            </a>
          </article>
        `;
      }

      function renderResults(filtered) {
        if (filtered.length === 0) {
          resultsElement.innerHTML = '<p class="rounded-3xl border border-slate-200 bg-slate-50 p-8 text-slate-600">No matching articles were found. Try a broader search term.</p>';
          return;
        }
        resultsElement.innerHTML = filtered.map(buildCard).join('');
      }

      function search(value) {
        const query = value.trim().toLowerCase();
        if (!query) {
          resultsElement.innerHTML = '<p class="rounded-3xl border border-slate-200 bg-slate-50 p-8 text-slate-600">Enter a search term above to filter the blog.</p>';
          return;
        }

        const filtered = data.filter((post) => {
          const terms = [post.title, post.description, ...post.categories, ...post.tags].join(' ').toLowerCase();
          return terms.includes(query);
        });

        renderResults(filtered);
      }

      searchInput.addEventListener('input', (event) => {
        search(event.target.value);
      });

      renderResults([]);
    </script>
  </body>
</html>
