---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const categories = Array.from(
  new Set(posts.flatMap((post) => post.data.categories ?? []))
).sort();
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Categories | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="site-container py-12">
      <section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-soft">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-700">Categories</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Browse articles by billing & coding topic.</h1>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {categories.map((category) => (
            <a href={`/categories/${category.toLowerCase().replace(/\s+/g, '-')}/`} class="group rounded-3xl border border-slate-200 bg-slate-50 p-6 transition hover:border-brand-300 hover:bg-white">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-brand-700">{category}</p>
              <p class="mt-4 text-slate-600">{posts.filter((post) => post.data.categories?.includes(category)).length} articles</p>
            </a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
