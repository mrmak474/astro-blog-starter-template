<section class="rounded-[32px] border border-slate-200 bg-white p-8 shadow-soft md:p-12">
  <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div class="space-y-6">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-700">Revenue cycle growth</p>
      <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
        Monetize your medical billing expertise with trust and clarity.
      </h2>
      <p class="max-w-2xl text-slate-600 sm:text-lg">
        Convert traffic into client engagements with practical case studies, complaint-safe coding strategy, and clear revenue optimization offers.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href="/about"
          class="inline-flex items-center justify-center rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-800"
          >Request a free audit</a
        >
        <a
          href="/about"
          class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-brand-700 hover:text-brand-700"
