---
import { SITE_TITLE } from '../consts';
---
<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-md">
  <div class="site-container flex flex-wrap items-center justify-between gap-4 py-4">
    <a href="/" class="text-xl font-semibold tracking-tight text-slate-900">{SITE_TITLE}</a>
    <nav class="flex flex-wrap items-center gap-4 text-sm font-medium text-slate-700">
      <a href="/" class="transition hover:text-brand-700">Home</a>
      <a href="/blog" class="transition hover:text-brand-700">Blog</a>
      <a href="/categories" class="transition hover:text-brand-700">Categories</a>
      <a href="/tags" class="transition hover:text-brand-700">Tags</a>
      <a href="/search" class="transition hover:text-brand-700">Search</a>
      <a href="/about" class="transition hover:text-brand-700">About</a>
    </nav>
    <a
      href="/about"
      class="inline-flex items-center rounded-full bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-soft transition hover:bg-brand-700"
      >Book a consultation</a
    >
  </div>
</header>
